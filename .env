# Database (Neon PostgreSQL)
# Pooled connection for runtime queries
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/hookrelay?sslmode=require
# Direct (non-pooled) connection for migrations
DATABASE_URL_NON_POOLING=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/hookrelay?sslmode=require

# Redis (Upstash)
REDIS_URL=redis://localhost:6379
REDIS_TOKEN=

# NextAuth
AUTH_SECRET=change-me-to-a-random-secret
AUTH_URL=http://localhost:3000

# App
NODE_ENV=development
WORKER_CONCURRENCY=10

# Email Alerts
EMAIL_PROVIDER=log
RESEND_API_KEY=
EMAIL_FROM=alerts@hookrelay.dev
DASHBOARD_URL=http://localhost:3000
