# Tracker (Next.js)
TRACKER_PORT=3000

# Admin (Next.js)
ADMIN_PORT=3002

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shiplens

# Redis
REDIS_URL=redis://localhost:6379

# Email (Resend)
