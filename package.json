{
  "name": "shiplens",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo run test:coverage && node scripts/merge-coverage.mjs",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "db:generate": "cd packages/db && drizzle-kit generate",
    "db:migrate": "cd packages/db && drizzle-kit migrate",
    "db:push": "cd packages/db && drizzle-kit push",
    "test:coverage": "turbo run test:coverage && node scripts/merge-coverage.mjs"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  },
  "packageManager": "npm@10.9.0"
}
